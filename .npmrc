# Required for React Native / Expo: Metro's resolver expects a flat
# node_modules tree. Without this, some native modules and Expo
# packages fail to resolve.
node-linker=hoisted

# Surface unmet peer deps rather than silently auto-installing them.
auto-install-peers=true

# Refuse to silently fall back to a different pnpm version than the
# one pinned in package.json's packageManager field.
package-manager-strict=true
